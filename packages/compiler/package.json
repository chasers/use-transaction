{
  "name": "@use-transaction/compiler",
  "version": "0.0.1",
  "description": "Babel plugin and Vite plugin for use-transaction — strips SQL and emits migrations at build time",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./babel-plugin": {
      "import": "./dist/babel-plugin.js",
      "types": "./dist/babel-plugin.d.ts"
    },
    "./vite-plugin": {
      "import": "./dist/vite-plugin.js",
      "types": "./dist/vite-plugin.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/generator": "^7.24.0",
    "@babel/plugin-syntax-jsx": "^7.24.0",
    "@babel/plugin-syntax-typescript": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@use-transaction/migration": "workspace:*"
  },
  "devDependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@types/babel__core": "^7.20.0",
    "@types/babel__generator": "^7.6.0",
    "@types/babel__traverse": "^7.20.0",
    "vitest": "^2.0.0",
    "vite": "^5.0.0"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
